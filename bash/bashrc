--color=prompt:#8ba4b0,hl:#c4746e
"

# ghq-fzf
ghq-fzf() {
    local src
    src=$(ghq list | fzf \
        --preview '
            repo=$(ghq root)/{}
            if ls $repo/README* >/dev/null 2>&1
                bat --color=always --style=header,grid --line-range :80 $repo/README*
            else
                ls -lah $repo
            fi
        '
    )

    if [ -n "$src" ]; then
        cd "$(ghq root)/$src" || return
    fi
}
bind '"\C-g": "ghq-fzf\n"'

