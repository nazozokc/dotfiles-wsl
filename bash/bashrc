__timer_start() {
  __timer_start_time=${__timer_start_time:-$SECONDS}
}
__timer_stop() {
  local elapsed=$(( SECONDS - __timer_start_time ))
  unset __timer_start_time
  if [ "$elapsed" -ge 2 ]; then
    __timer_show=" \[\e[1;33m\][⏱ ${elapsed}s]\[\e[0m\]"
  else
    __timer_show=""
  fi
}
trap '__timer_start' DEBUG

__git_info() {
  local branch status_str
  branch=$(git branch 2>/dev/null | grep '^\*' | sed 's/\* //')
  [ -z "$branch" ] && return

  local porcelain
  porcelain=$(git status --porcelain 2>/dev/null)

  local modified untracked staged
  modified=$(echo "$porcelain" | grep -c '^ M\|^M ' || true)
  untracked=$(echo "$porcelain" | grep -c '^??' || true)
  staged=$(echo "$porcelain" | grep -c '^[MADRCU]' || true)
  modified=${modified:-0}
  untracked=${untracked:-0}
  staged=${staged:-0}

  status_str=""
  [ "$staged"    -gt 0 ] && status_str+=" \[\e[1;32m\]+${staged}\[\e[0m\]"
  [ "$modified"  -gt 0 ] && status_str+=" \[\e[1;31m\]✎${modified}\[\e[0m\]"
  [ "$untracked" -gt 0 ] && status_str+=" \[\e[1;35m\]?${untracked}\[\e[0m\]"

  echo " \[\e[1;33m\][ \[\e[1;36m\]${branch}${status_str}\[\e[1;33m\]]\[\e[0m\]"
}

__venv_info() {
  [ -n "$VIRTUAL_ENV" ] && echo " \[\e[1;35m\][🐍 $(basename $VIRTUAL_ENV)]\[\e[0m\]"
}

__node_info() {
  [ -f ".nvmrc" ] || [ -f "package.json" ] || return
  local ver
  ver=$(node -v 2>/dev/null)
  [ -n "$ver" ] && echo " \[\e[1;32m\][⬡ ${ver}]\[\e[0m\]"
}

__set_ps1() {
  local exit_code=$?
  __timer_stop

  local prompt_char
  if [ "$exit_code" -eq 0 ]; then
    prompt_char="\[\e[1;32m\]❯\[\e[0m\]"
  else
    prompt_char="\[\e[1;31m\]❯ [✗${exit_code}]\[\e[0m\]"
  fi

  PS1="\[\e[1;34m\]╭─\[\e[0m\]"
  PS1+="\[\e[1;30m\][\[\e[0;37m\]\t\[\e[1;30m\]]\[\e[0m\]"
  PS1+=" \[\e[1;34m\][\[\e[1;36m\]\u\[\e[1;34m\]@\[\e[1;35m\]\h\[\e[1;34m\]]\[\e[0m\]"
  PS1+=" \[\e[1;34m\][\[\e[1;32m\]\w\[\e[1;34m\]]\[\e[0m\]"
  PS1+="$(__git_info)"
  PS1+="$(__venv_info)"
  PS1+="$(__node_info)"
  PS1+="${__timer_show}"
  PS1+="\n\[\e[1;34m\]╰─\[\e[0m\]${prompt_char} "
}

PROMPT_COMMAND='__set_ps1'
